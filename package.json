{
  "name": "figma-svg-exporter",
  "version": "1.0.0",
  "description": "Export SVG assets from Figma with SVGO optimization and TypeScript type generation",
  "author": "Slava Cherkesov",
  "bin": {
    "figma-svg-exporter": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "lint": "oxlint ./src",
    "lint:fix": "oxlint --fix ./src",
    "type-check": "tsc --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "build": "bun run build.ts && tsc",
    "release": "semantic-release"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "figma-js": "^1.16.0",
    "figma-transformer": "^2.1.0",
    "node-fetch": "^3.3.2",
    "svgo": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@jest/globals": "^29.7.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.0",
    "jest": "^29.7.0",
    "lefthook": "^2.0.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "semantic-release": "^24.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/git": "^10.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0"
  },
  "peerDependencies": {
    "figma-js": "1.x",
    "figma-transformer": "2.x",
    "node-fetch": "3.x",
    "svgo": "4.x"
  }
}
